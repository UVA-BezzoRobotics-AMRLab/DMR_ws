<mvsim_world version="1.0">
    <simul_timestep>0.005</simul_timestep>

    <gui>
        <ortho>false</ortho>
        <show_forces>false</show_forces>
        <cam_distance>80</cam_distance>
        <cam_azimuth>30</cam_azimuth>
        <cam_elevation>45</cam_elevation>
        <fov_deg>60</fov_deg>
        <refresh_fps>30</refresh_fps>
    </gui>

    <block:class name="internal_obs">
        <mass>0</mass>
        <color>#800000</color> 
        <zmax>2.0</zmax>
        <ground_friction>0.8</ground_friction>
        <shape>
            <pt>-1.0 -18.75</pt>
            <pt>-1.0  18.75</pt>
            <pt> 1.0  18.75</pt>
            <pt> 1.0 -18.75</pt>
        </shape>
    </block:class>

    <block:class name="long_wall">
        <mass>0</mass>
        <color>#404040</color>
        <zmax>2.0</zmax>
        <shape>
            <pt>-1.0 -25</pt>
            <pt>-1.0  25</pt>
            <pt> 1.0  25</pt>
            <pt> 1.0 -25</pt>
        </shape>
    </block:class>

    <block:class name="long_wall_horiz">
        <mass>0</mass>
        <color>#404040</color>
        <zmax>2.0</zmax>
        <shape>
            <pt>-25 -1.0</pt>
            <pt>-25  1.0</pt>
            <pt> 25  1.0</pt>
            <pt> 25 -1.0</pt>
        </shape>
    </block:class>

    <block class="long_wall"> <init_pose>26 25 0</init_pose> </block>
    <block class="long_wall"> <init_pose>-26 25 0</init_pose> </block>
    <block class="long_wall_horiz"> <init_pose>0 -1.0 0</init_pose> </block>
    <block class="long_wall_horiz"> <init_pose>0 51.0 0</init_pose> </block>

    <block class="internal_obs">
        <init_pose>-8.67 31.25 0</init_pose>
    </block>

    <block class="internal_obs">
        <init_pose>8.67 18.75 0</init_pose>
    </block>

    <include file="/opt/ros/humble/share/mvsim/definitions/jackal.vehicle.xml" default_sensors="false" />

    <vehicle name="r1" class="jackal">
        <init_pose>-20 45 0</init_pose> 

        <!-- no noise -->
        <!-- <odom_params>
            <noise_v_linear>0.0</noise_v_linear>
            <noise_v_angular>0.0</noise_v_angular>
            <noise_v_lateral>0.0</noise_v_lateral>
        </odom_params> -->

        <include file="/opt/ros/humble/share/mvsim/definitions/lidar2d.sensor.xml" 
          sensor_x="0.15" sensor_z="0.33" sensor_yaw="0" sensor_name="laser1" 
        />
    </vehicle>

